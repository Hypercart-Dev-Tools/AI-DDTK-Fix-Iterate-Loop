#!/usr/bin/env bash
# ============================================================
# AI-DDTK Playwright Auth Helper
# Generates and caches WordPress admin auth state for Playwright
# ============================================================
#
# Requires:
#   - WP-CLI (wp) or local-wp wrapper
#   - Node.js + Playwright (npm install -g playwright)
#   - dev-login-cli.php mu-plugin installed on target site
#
# Usage:
#   pw-auth login --site-url http://my-site.local
#   pw-auth login --site-url http://my-site.local --user=editor
#   pw-auth login --site-url http://my-site.local --wp-cli "local-wp my-site"
#   pw-auth login --site-url http://my-site.local --redirect /wp-admin/site-editor.php
#   pw-auth status
#   pw-auth clear
#
# Auth state is saved to: ./temp/playwright/.auth/<user>.json (relative to CWD)
# Reuses cached state if less than 12 hours old (configurable with --max-age).
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_ROOT="$(dirname "$SCRIPT_DIR")"
AUTH_DIR="$(pwd)/temp/playwright/.auth"
DEFAULT_MAX_AGE_HOURS=12
TEMP_FILES=()

# ============================================================
# HELPERS
# ============================================================

show_help() {
    cat <<'EOF'
AI-DDTK Playwright Auth Helper

Generates one-time WP admin login URLs via WP-CLI and captures
the authenticated session as Playwright storageState for reuse.

Auth state is stored in the current working directory at:
  ./temp/playwright/.auth/<user>.json

Usage:
  pw-auth <command> [options]

Commands:
  login    Generate login URL, authenticate via Playwright, save storageState
  status   Show cached auth files (age, user, size, freshness)
  clear    Remove cached auth state files

Options (login):
  --site-url <url>       WordPress site URL (required)
  --user <login>         WordPress username (default: admin)
  --wp-cli <cmd>         WP-CLI command prefix (default: wp)
                         e.g., "local-wp my-site" for Local by Flywheel
  --redirect <path>      WP admin path to land on after login
  --max-age <hours>      Reuse cached auth if younger than this (default: 12)
                         Fresh cache entries are live-validated before reuse
  --force                Skip cache age check, always re-authenticate
  --auth-file <path>     Custom path for auth state file
  --headed               Run Playwright in headed mode (visible browser)

Examples:
  # Basic — authenticate as admin on a Local site
  pw-auth login --site-url http://my-site.local --wp-cli "local-wp my-site"

  # Reuse in Playwright scripts
  # const context = await browser.newContext({
  #   storageState: 'temp/playwright/.auth/admin.json'
  # });

  # Force re-auth even if cache is fresh
  pw-auth login --site-url http://my-site.local --force

  # Check cached auth file freshness
  pw-auth status
EOF
}

log_info() {
    echo "[pw-auth] $*"
}

log_error() {
    echo "[pw-auth] ERROR: $*" >&2
}

track_temp_file() {
    local temp_file="${1:-}"

    if [ -n "$temp_file" ]; then
        TEMP_FILES+=("$temp_file")
    fi
}

cleanup_temp_file() {
    local target_file="${1:-}"
    local temp_file
    local -a remaining_files=()

    if [ -n "$target_file" ]; then
        rm -f "$target_file" 2>/dev/null || true
    fi

    for temp_file in "${TEMP_FILES[@]:-}"; do
        if [ -n "$temp_file" ] && [ "$temp_file" != "$target_file" ]; then
            remaining_files+=("$temp_file")
        fi
    done

    if [ "${remaining_files[0]+set}" = "set" ]; then
        TEMP_FILES=("${remaining_files[@]}")
    else
        TEMP_FILES=()
    fi
}

cleanup_all_temp_files() {
    local temp_file

    for temp_file in "${TEMP_FILES[@]:-}"; do
        [ -n "$temp_file" ] && rm -f "$temp_file" 2>/dev/null || true
    done

    TEMP_FILES=()
}

trap cleanup_all_temp_files EXIT
trap 'cleanup_all_temp_files; exit 130' INT
trap 'cleanup_all_temp_files; exit 143' TERM

node_can_resolve_playwright() {
    node -e "require('playwright')" >/dev/null 2>&1 || \
    node -e "require('playwright-core')" >/dev/null 2>&1
}

append_node_path() {
    local extra_path="$1"
    local current_node_path="${NODE_PATH:-}"

    if [ -z "$current_node_path" ]; then
        echo "$extra_path"
        return
    fi

    case ":$current_node_path:" in
        *":$extra_path:"*)
            echo "$current_node_path"
            ;;
        *)
            echo "$current_node_path:$extra_path"
            ;;
    esac
}

ensure_playwright_resolvable() {
    if node_can_resolve_playwright; then
        return 0
    fi

    if ! command -v npm >/dev/null 2>&1; then
        return 1
    fi

    local npm_root
    npm_root="$(npm root -g 2>/dev/null || true)"

    if [ -z "$npm_root" ] || [ ! -d "$npm_root" ]; then
        return 1
    fi

    local candidate_node_path
    candidate_node_path="$(append_node_path "$npm_root")"

    if NODE_PATH="$candidate_node_path" node -e "require('playwright')" >/dev/null 2>&1 || \
       NODE_PATH="$candidate_node_path" node -e "require('playwright-core')" >/dev/null 2>&1; then
        export NODE_PATH="$candidate_node_path"
        log_info "Auto-configured NODE_PATH for Playwright: $npm_root"
        return 0
    fi

    return 1
}

join_args_for_display() {
    local out=""
    local arg
    local quoted

    for arg in "$@"; do
        quoted="$(printf '%q' "$arg")"
        if [ -n "$out" ]; then
            out="$out "
        fi
        out="$out$quoted"
    done

    echo "$out"
}

parse_command_prefix() {
    local raw_command="$1"

    node - "$raw_command" <<'NODE'
const input = process.argv[2] ?? '';
const tokens = [];
let current = '';
let quote = null;
let escaping = false;
let tokenStarted = false;

function pushToken() {
  tokens.push(current);
  current = '';
  tokenStarted = false;
}

for (let i = 0; i < input.length; i += 1) {
  const ch = input[i];

  if (escaping) {
    current += ch;
    escaping = false;
    tokenStarted = true;
    continue;
  }

  if (quote === "'") {
    if (ch === "'") {
      quote = null;
    } else {
      current += ch;
      tokenStarted = true;
    }
    continue;
  }

  if (quote === '"') {
    if (ch === '"') {
      quote = null;
      continue;
    }

    if (ch === '\\') {
      const next = input[i + 1];
      if (next !== undefined && '"\\$`'.includes(next)) {
        current += next;
        i += 1;
        tokenStarted = true;
        continue;
      }
    }

    current += ch;
    tokenStarted = true;
    continue;
  }

  if (ch === '\\') {
    escaping = true;
    tokenStarted = true;
    continue;
  }

  if (ch === "'" || ch === '"') {
    quote = ch;
    tokenStarted = true;
    continue;
  }

  if (/\s/.test(ch)) {
    if (tokenStarted || current.length > 0) {
      pushToken();
    }
    continue;
  }

  current += ch;
  tokenStarted = true;
}

if (escaping) {
  console.error('Trailing escape in --wp-cli value.');
  process.exit(1);
}

if (quote) {
  console.error('Unterminated quote in --wp-cli value.');
  process.exit(1);
}

if (tokenStarted || current.length > 0) {
  pushToken();
}

if (tokens.length === 0) {
  console.error('Empty --wp-cli command prefix.');
  process.exit(1);
}

for (const token of tokens) {
  console.log(token);
}
NODE
}

url_origin() {
    local raw_url="$1"

    node - "$raw_url" <<'NODE'
try {
  console.log(new URL(process.argv[2]).origin);
} catch (error) {
  console.error(error.message);
  process.exit(1);
}
NODE
}

create_temp_file() {
    local prefix="$1"
    local suffix="${2:-}"
    local tmp_dir="${TMPDIR:-/tmp}"
    local temp_path=""
    local suffixed_path=""

    temp_path="$(mktemp "${tmp_dir%/}/${prefix}-XXXXXX")" || return 1

    if [ -z "$suffix" ]; then
        printf '%s\n' "$temp_path"
        return 0
    fi

    suffixed_path="${temp_path}${suffix}"
    mv "$temp_path" "$suffixed_path" || {
        rm -f "$temp_path"
        return 1
    }

    printf '%s\n' "$suffixed_path"
}

# Check if a file is older than N hours
file_age_hours() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "999999"
        return
    fi

    local now
    local mod_time
    now="$(date +%s)"

    if [ "$(uname)" = "Darwin" ]; then
        mod_time="$(stat -f %m "$file")"
    else
        mod_time="$(stat -c %Y "$file")"
    fi

    echo $(( (now - mod_time) / 3600 ))
}

run_playwright_auth_flow() {
    local mode="$1"
    local site_url="$2"
    local auth_file="$3"
    local login_url="$4"
    local headless_val="$5"
    local pw_script
    local exit_code

    pw_script="$(create_temp_file "pw-auth" ".js")" || {
        log_error "Failed to create temporary Playwright script file."
        return 1
    }
    track_temp_file "$pw_script"

    cat > "$pw_script" <<'PLAYWRIGHT_SCRIPT'
// pw-auth: Playwright login + storageState capture / validation
// Usage: node <script> <mode> <site_url> <auth_file> <login_url> <headless>

let chromium;
try { ({ chromium } = require('playwright')); }
catch { ({ chromium } = require('playwright-core')); }

const [,, mode, siteUrl, authFile, loginUrl, headlessFlag] = process.argv;
const headless = headlessFlag !== 'false';
const parsedSiteUrl = new URL(siteUrl);
const origin = parsedSiteUrl.origin;
const baseUrl = siteUrl.replace(/\/+$/, '');
const host = parsedSiteUrl.hostname.toLowerCase();
const ignoreHTTPSErrors = parsedSiteUrl.protocol === 'https:' && (
    host === 'localhost' ||
    host === '127.0.0.1' ||
    host === '::1' ||
    host.endsWith('.local') ||
    host.endsWith('.test')
);

async function assertNotWpErrorPage(page) {
    const bodyText = await page.textContent('body').catch(() => '');
    const pageTitle = await page.title().catch(() => '');
    const bodyId = await page.getAttribute('body', 'id').catch(() => '');
    const hasWpDieMarkup = (await page.locator('#error-page, .wp-die-message').count().catch(() => 0)) > 0;
    const fatalMarkers = [
        'There has been a critical error on this website.',
        'has been a critical error on this website.',
        'Dev login is disabled in production environments.',
        'Dev login is not allowed on this host.',
        'Invalid or expired login link.',
        'Invalid user.',
        'Error establishing a database connection'
    ];
    const looksLikeWpErrorPage =
        bodyId === 'error-page' ||
        hasWpDieMarkup ||
        pageTitle.includes('WordPress › Error') ||
        fatalMarkers.some(marker => bodyText.includes(marker));

    if (looksLikeWpErrorPage) {
        throw new Error('WordPress returned an error page. Body: ' + bodyText.substring(0, 200));
    }
}

async function assertAuthCookie(context) {
    const cookies = await context.cookies(origin);
    const authCookie = cookies.find(cookie => cookie.name.startsWith('wordpress_logged_in_'));

    if (!authCookie) {
        throw new Error('No wordpress_logged_in_ cookie found. Cookies present: ' + cookies.map(cookie => cookie.name).join(', '));
    }
}

async function assertWpAdminAccessible(page) {
    await page.goto(baseUrl + '/wp-admin/', {
        waitUntil: 'domcontentloaded',
        timeout: 15000,
    });

    if (page.url().includes('wp-login.php')) {
        throw new Error('wp-admin redirected to wp-login.php — session is not valid.');
    }
}

(async () => {
    let browser;

    try {
        browser = await chromium.launch({ headless });
        const contextOptions = ignoreHTTPSErrors ? { ignoreHTTPSErrors: true } : {};

        if (mode === 'validate') {
            contextOptions.storageState = authFile;
        }

        const context = await browser.newContext(contextOptions);
        const page = await context.newPage();

        if (mode === 'login') {
            await page.goto(loginUrl, { waitUntil: 'networkidle', timeout: 30000 });

            if (page.url().includes('wp-login.php')) {
                throw new Error('Login failed — landed on wp-login.php. The login token may have expired or the mu-plugin may not be active.');
            }

            await assertNotWpErrorPage(page);
            await assertAuthCookie(context);
            await assertWpAdminAccessible(page);
            await assertNotWpErrorPage(page);

            await context.storageState({ path: authFile });
            console.log('[pw-auth] Auth state saved to: ' + authFile);
            console.log('[pw-auth] Verified: wordpress_logged_in_ cookie present, wp-admin accessible.');
        } else if (mode === 'validate') {
            await assertWpAdminAccessible(page);
            await assertNotWpErrorPage(page);
            await assertAuthCookie(context);
            console.log('[pw-auth] Cached auth is still valid.');
        } else {
            throw new Error('Unknown mode: ' + mode);
        }
    } catch (err) {
        console.error('[pw-auth] ERROR: ' + err.message);
        process.exit(1);
    } finally {
        if (browser) {
            await browser.close();
        }
    }
})();
PLAYWRIGHT_SCRIPT

    set +e
    node "$pw_script" "$mode" "$site_url" "$auth_file" "$login_url" "$headless_val"
    exit_code=$?
    set -e
    cleanup_temp_file "$pw_script"

    return $exit_code
}

# ============================================================
# COMMANDS
# ============================================================

do_login() {
    local site_url=""
    local wp_user="admin"
    local wp_cli_cmd="wp"
    local redirect=""
    local max_age="$DEFAULT_MAX_AGE_HOURS"
    local force=false
    local auth_file=""
    local headed=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --site-url)   site_url="$2"; shift 2 ;;
            --user)       wp_user="$2"; shift 2 ;;
            --wp-cli)     wp_cli_cmd="$2"; shift 2 ;;
            --redirect)   redirect="$2"; shift 2 ;;
            --max-age)    max_age="$2"; shift 2 ;;
            --force)      force=true; shift ;;
            --auth-file)  auth_file="$2"; shift 2 ;;
            --headed)     headed="--headed"; shift ;;
            -h|--help)    show_help; exit 0 ;;
            *) log_error "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [ -z "$site_url" ]; then
        log_error "--site-url is required"
        echo ""
        show_help
        exit 1
    fi

    # Determine auth file path
    if [ -z "$auth_file" ]; then
        local safe_user
        safe_user="$(echo "$wp_user" | tr -cd '[:alnum:]-_')"
        auth_file="$AUTH_DIR/${safe_user}.json"
    fi

    # Check prerequisites
    if ! command -v node >/dev/null 2>&1; then
        log_error "Node.js is required but not installed."
        exit 1
    fi

    # Verify Playwright is resolvable by Node
    if ! ensure_playwright_resolvable; then
        log_error "Playwright is not resolvable by Node.js."
        log_error ""
        log_error "Install globally:  npm install -g playwright"
        log_error "Then install browsers:  npx playwright install chromium"
        log_error ""
        log_error "pw-auth already tried the global npm root from: npm root -g"
        log_error "If Node still can't find Playwright, set NODE_PATH manually:"
        log_error "  export NODE_PATH=\"\$(npm root -g)\""
        exit 1
    fi

    # Check cache
    if [ "$force" = false ] && [ -f "$auth_file" ]; then
        local age
        local validate_log
        local validate_summary

        age="$(file_age_hours "$auth_file")"
        if [ "$age" -lt "$max_age" ]; then
            log_info "Cached auth is ${age}h old (max: ${max_age}h). Verifying live session..."
            validate_log="$(create_temp_file "pw-auth-validate" ".log")" || {
                log_error "Failed to create temporary validation log file."
                return 1
            }
            track_temp_file "$validate_log"
            if run_playwright_auth_flow "validate" "$site_url" "$auth_file" "" "true" >"$validate_log" 2>&1; then
                cleanup_temp_file "$validate_log"
                log_info "Cached auth passed live validation. Reusing: $auth_file"
                log_info "Use --force to re-authenticate."
                exit 0
            fi

            if [ -s "$validate_log" ]; then
                validate_summary="$(tail -n 1 "$validate_log" | tr -d '\r')"
                if [ -n "$validate_summary" ]; then
                    log_info "Cached auth probe failed: $validate_summary"
                fi
            fi
            cleanup_temp_file "$validate_log"
            log_info "Cached auth is fresh but no longer valid. Re-authenticating..."
        else
            log_info "Cached auth is ${age}h old (max: ${max_age}h). Re-authenticating..."
        fi
    fi

    # Build WP-CLI login command as an array (no eval — avoids command injection)
    local parsed_wp_cli_cmd
    local cmd_part
    local wp_cmd_display
    local wp_prefix_display
    local stderr_file
    local -a wp_cmd_args
    local -a wp_cmd_prefix_args

    parsed_wp_cli_cmd="$(parse_command_prefix "$wp_cli_cmd")" || {
        log_error "Could not parse --wp-cli value: $wp_cli_cmd"
        log_error "Pass only a command prefix, e.g. --wp-cli \"local-wp my-site\""
        exit 1
    }

    while IFS= read -r cmd_part || [ -n "$cmd_part" ]; do
        wp_cmd_prefix_args+=("$cmd_part")
    done <<< "$parsed_wp_cli_cmd"

    wp_cmd_args=("${wp_cmd_prefix_args[@]}")
    wp_cmd_args+=( "dev" "login" "--user=$wp_user" "--format=url" )
    if [ -n "$redirect" ]; then
        wp_cmd_args+=( "--redirect=$redirect" )
    fi

    wp_cmd_display="$(join_args_for_display "${wp_cmd_args[@]}")"
    wp_prefix_display="$(join_args_for_display "${wp_cmd_prefix_args[@]}")"

    log_info "Generating one-time login URL..."
    log_info "Running: $wp_cmd_display"

    local login_url
    stderr_file="$(create_temp_file "pw-auth-wpcli" ".log")" || {
        log_error "Failed to create temporary WP-CLI stderr log file."
        return 1
    }
    track_temp_file "$stderr_file"
    login_url="$("${wp_cmd_args[@]}" 2>"$stderr_file")" || {
        log_error "WP-CLI command failed while generating the one-time login URL."
        if [ -s "$stderr_file" ]; then
            log_error "WP-CLI stderr:"
            while IFS= read -r line; do
                log_error "  $line"
            done < "$stderr_file"
        fi
        log_error "  Template: ~/bin/ai-ddtk/templates/dev-login-cli.php"
        log_error "  Install:  cp ~/bin/ai-ddtk/templates/dev-login-cli.php <site>/wp-content/mu-plugins/"
        log_error "Run these next:"
        log_error "  $wp_prefix_display option get home"
        log_error "  $wp_prefix_display eval 'echo wp_get_environment_type(), PHP_EOL;'"
        log_error "  $wp_prefix_display user get $wp_user --field=user_login"
        log_error "  $wp_prefix_display eval 'echo ( file_exists( WP_CONTENT_DIR . \"/mu-plugins/dev-login-cli.php\" ) ? \"mu-plugin present\" : \"mu-plugin missing\" ), PHP_EOL;'"
        log_error "  $wp_prefix_display dev login --user=$wp_user --format=url"
        cleanup_temp_file "$stderr_file"
        exit 1
    }
    cleanup_temp_file "$stderr_file"

    # Trim any whitespace / extra lines — take only the last line (the URL)
    login_url="$(echo "$login_url" | tail -n 1 | tr -d '[:space:]')"

    if [ -z "$login_url" ]; then
        log_error "No login URL returned from WP-CLI."
        exit 1
    fi

    # Validate that the login URL matches the expected --site-url origin
    local expected_origin
    local login_origin
    expected_origin="$(url_origin "$site_url")" || {
        log_error "Invalid --site-url: $site_url"
        exit 1
    }
    login_origin="$(url_origin "$login_url")" || {
        log_error "WP-CLI returned an invalid login URL: $login_url"
        exit 1
    }
    if [ "$login_origin" != "$expected_origin" ]; then
        log_error "Login URL origin mismatch."
        log_error "  Expected origin: $expected_origin"
        log_error "  Got origin:      $login_origin"
        log_error "  Got URL:         $login_url"
        log_error "Check that --site-url matches the site's home_url()."
        exit 1
    fi

    log_info "Login URL obtained. Launching Playwright to capture auth state..."

    # Create auth directory
    mkdir -p "$(dirname "$auth_file")"

    local headless_val
    headless_val="$( [ -n "$headed" ] && echo "false" || echo "true" )"

    run_playwright_auth_flow "login" "$site_url" "$auth_file" "$login_url" "$headless_val"

    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log_error "Playwright auth capture failed."
        exit 1
    fi

    log_info "Done. Use in Playwright scripts:"
    log_info "  storageState: '$auth_file'"
}

do_status() {
    mkdir -p "$AUTH_DIR"

    local found=false
    for f in "$AUTH_DIR"/*.json; do
        [ -f "$f" ] || continue
        found=true
        local age
        age="$(file_age_hours "$f")"
        local user
        user="$(basename "$f" .json)"
        local size
        size="$(wc -c < "$f" | tr -d ' ')"

        echo "  User: $user"
        echo "  File: $f"
        echo "  Age:  ${age}h"
        echo "  Size: ${size} bytes"

        if [ "$age" -lt "$DEFAULT_MAX_AGE_HOURS" ]; then
            echo "  Status: FRESH (< ${DEFAULT_MAX_AGE_HOURS}h; live validation happens on login)"
        else
            echo "  Status: STALE (>= ${DEFAULT_MAX_AGE_HOURS}h, will re-auth on next login)"
        fi
        echo ""
    done

    if [ "$found" = false ]; then
        echo "No cached auth state found in $AUTH_DIR"
        echo "Run: pw-auth login --site-url <url>"
    fi
}

do_clear() {
    if [ -d "$AUTH_DIR" ]; then
        rm -f "$AUTH_DIR"/*.json
        log_info "Cleared auth state from $AUTH_DIR"
    else
        log_info "No auth directory found. Nothing to clear."
    fi
}

# ============================================================
# MAIN
# ============================================================

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    login)
        do_login "$@"
        ;;
    status)
        do_status
        ;;
    clear)
        do_clear
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        log_error "Unknown command: $COMMAND"
        echo ""
        show_help
        exit 1
        ;;
esac
