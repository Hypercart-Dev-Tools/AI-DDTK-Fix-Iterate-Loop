#!/usr/bin/env bash
# ============================================================
# AI-DDTK Playwright Auth Helper
# Generates and caches WordPress admin auth state for Playwright
# ============================================================
#
# Requires:
#   - WP-CLI (wp) or local-wp wrapper
#   - Node.js + Playwright (npm install -g playwright)
#   - dev-login-cli.php mu-plugin installed on target site
#
# Usage:
#   pw-auth login --site-url http://my-site.local
#   pw-auth login --site-url http://my-site.local --user=editor
#   pw-auth login --site-url http://my-site.local --wp-cli "local-wp my-site"
#   pw-auth login --site-url http://my-site.local --redirect /wp-admin/site-editor.php
#   pw-auth doctor --site-url http://my-site.local
#   pw-auth check dom --url http://my-site.local/wp-admin/ --selector "#wpbody" --extract text
#   pw-auth status
#   pw-auth clear
#
# Auth state is saved to: ./temp/playwright/.auth/<user>.json (relative to CWD)
# Reuses cached state if less than 12 hours old (configurable with --max-age).
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_ROOT="$(dirname "$SCRIPT_DIR")"
AUTH_DIR="$(pwd)/temp/playwright/.auth"
DEFAULT_MAX_AGE_HOURS=12
DEFAULT_CHECK_TIMEOUT_MS=15000
TEMP_FILES=()

# ============================================================
# HELPERS
# ============================================================

show_help() {
    cat <<'EOF'
AI-DDTK Playwright Auth Helper

Generates one-time WP admin login URLs via WP-CLI and captures
the authenticated session as Playwright storageState for reuse.

Auth state is stored in the current working directory at:
  ./temp/playwright/.auth/<user>.json

Usage:
  pw-auth <command> [options]

Commands:
  login    Generate login URL, authenticate via Playwright, save storageState
  doctor   Check Playwright + pw-auth readiness for a specific site/user
  check    Inspect a page/selector using optional cached auth
  status   Show cached auth files (age, user, size, freshness)
  clear    Remove cached auth state files

Options (login and doctor):
  --site-url <url>       WordPress site URL (required)
  --user <login>         WordPress username (default: admin)
  --wp-cli <cmd>         WP-CLI command prefix (default: wp)
                         e.g., "local-wp my-site" for Local by Flywheel

Options (doctor):
  --format <text|json>   Output format for readiness report (default: text)

Options (check dom):
  --url <url>            Page URL to open (required)
  --selector <css>       CSS selector to inspect (required)
  --extract <mode>       One of: exists, text, html (required)
  --user <login>         Resolve default auth state from ./temp/playwright/.auth/<user>.json
  --auth-state <path>    Explicit Playwright storageState file to use if present
  --auth-origin <origin> Cookie origin to inspect for auth reuse (default: inferred from --url)
  --timeout-ms <ms>      Navigation/selector timeout in milliseconds (default: 15000)
  --format <text|json>   Output format (default: text)
  --output-dir <dir>     Directory for result artifacts (default: temp/playwright/checks/<run-id>/)

Options (login):
  --redirect <path>      WP admin path to land on after login
  --max-age <hours>      Reuse cached auth if younger than this (default: 12)
                         Fresh cache entries are live-validated before reuse
  --force                Skip cache age check, always re-authenticate
  --auth-file <path>     Custom path for auth state file
  --headed               Run Playwright in headed mode (visible browser)

Examples:
  # Basic — authenticate as admin on a Local site
  pw-auth login --site-url http://my-site.local --wp-cli "local-wp my-site"

  # Reuse in Playwright scripts
  # const context = await browser.newContext({
  #   storageState: 'temp/playwright/.auth/admin.json'
  # });

  # Force re-auth even if cache is fresh
  pw-auth login --site-url http://my-site.local --force

  # Check cached auth file freshness
  pw-auth status

  # Check Playwright/wp-auth readiness for a site
  pw-auth doctor --site-url http://my-site.local --wp-cli "local-wp my-site"

  # Get a machine-readable readiness report
  pw-auth doctor --site-url http://my-site.local --format json

  # Inspect a wp-admin surface using cached auth
  pw-auth check dom --url http://my-site.local/wp-admin/widgets.php --selector "#widgets-right" --extract html --user admin --format json
EOF
}

log_info() {
    echo "[pw-auth] $*"
}

log_error() {
    echo "[pw-auth] ERROR: $*" >&2
}

track_temp_file() {
    local temp_file="${1:-}"

    if [ -n "$temp_file" ]; then
        TEMP_FILES+=("$temp_file")
    fi
}

cleanup_temp_file() {
    local target_file="${1:-}"
    local temp_file
    local -a remaining_files=()

    if [ -n "$target_file" ]; then
        rm -f "$target_file" 2>/dev/null || true
    fi

    for temp_file in "${TEMP_FILES[@]:-}"; do
        if [ -n "$temp_file" ] && [ "$temp_file" != "$target_file" ]; then
            remaining_files+=("$temp_file")
        fi
    done

    if [ "${remaining_files[0]+set}" = "set" ]; then
        TEMP_FILES=("${remaining_files[@]}")
    else
        TEMP_FILES=()
    fi
}

cleanup_all_temp_files() {
    local temp_file

    for temp_file in "${TEMP_FILES[@]:-}"; do
        [ -n "$temp_file" ] && rm -f "$temp_file" 2>/dev/null || true
    done

    TEMP_FILES=()
}

trap cleanup_all_temp_files EXIT
trap 'cleanup_all_temp_files; exit 130' INT
trap 'cleanup_all_temp_files; exit 143' TERM

node_can_resolve_playwright() {
    node -e "require('playwright')" >/dev/null 2>&1 || \
    node -e "require('playwright-core')" >/dev/null 2>&1
}

append_node_path() {
    local extra_path="$1"
    local current_node_path="${NODE_PATH:-}"

    if [ -z "$current_node_path" ]; then
        echo "$extra_path"
        return
    fi

    case ":$current_node_path:" in
        *":$extra_path:"*)
            echo "$current_node_path"
            ;;
        *)
            echo "$current_node_path:$extra_path"
            ;;
    esac
}

ensure_playwright_resolvable() {
    local quiet="${1:-false}"

    if node_can_resolve_playwright; then
        return 0
    fi

    if ! command -v npm >/dev/null 2>&1; then
        return 1
    fi

    local npm_root
    npm_root="$(npm root -g 2>/dev/null || true)"

    if [ -z "$npm_root" ] || [ ! -d "$npm_root" ]; then
        return 1
    fi

    local candidate_node_path
    candidate_node_path="$(append_node_path "$npm_root")"

    if NODE_PATH="$candidate_node_path" node -e "require('playwright')" >/dev/null 2>&1 || \
       NODE_PATH="$candidate_node_path" node -e "require('playwright-core')" >/dev/null 2>&1; then
        export NODE_PATH="$candidate_node_path"
        if [ "$quiet" != "true" ]; then
            log_info "Auto-configured NODE_PATH for Playwright: $npm_root"
        fi
        return 0
    fi

    return 1
}

join_args_for_display() {
    local out=""
    local arg
    local quoted

    for arg in "$@"; do
        quoted="$(printf '%q' "$arg")"
        if [ -n "$out" ]; then
            out="$out "
        fi
        out="$out$quoted"
    done

    echo "$out"
}

parse_command_prefix() {
    local raw_command="$1"

    node "${SCRIPT_DIR}/pw-auth-helpers/parse-prefix.js" "$raw_command"
}

url_origin() {
    local raw_url="$1"

    node "${SCRIPT_DIR}/pw-auth-helpers/url-origin.js" "$raw_url"
}

create_temp_file() {
    local prefix="$1"
    local suffix="${2:-}"
    local tmp_dir="${TMPDIR:-/tmp}"
    local temp_path=""
    local suffixed_path=""

    temp_path="$(mktemp "${tmp_dir%/}/${prefix}-XXXXXX")" || return 1

    if [ -z "$suffix" ]; then
        printf '%s\n' "$temp_path"
        return 0
    fi

    suffixed_path="${temp_path}${suffix}"
    mv "$temp_path" "$suffixed_path" || {
        rm -f "$temp_path"
        return 1
    }

    printf '%s\n' "$suffixed_path"
}

sanitize_auth_user_fragment() {
    echo "$1" | tr -cd '[:alnum:]-_'
}

default_auth_file_for_user() {
    local safe_user
    safe_user="$(sanitize_auth_user_fragment "$1")"

    if [ -z "$safe_user" ]; then
        safe_user="user"
    fi

    printf '%s\n' "$AUTH_DIR/${safe_user}.json"
}

display_path() {
    local target_path="$1"
    local cwd
    cwd="$(pwd)"

    case "$target_path" in
        "$cwd"/*)
            printf '%s\n' "${target_path#"$cwd"/}"
            ;;
        *)
            printf '%s\n' "$target_path"
            ;;
    esac
}

json_escape() {
    local value="$1"
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    value=${value//$'\r'/\\r}
    value=${value//$'\t'/\\t}
    printf '%s' "$value"
}

# Check if a file is older than N hours
file_age_hours() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "999999"
        return
    fi

    local now
    local mod_time
    now="$(date +%s)"

    if [ "$(uname)" = "Darwin" ]; then
        mod_time="$(stat -f %m "$file")"
    else
        mod_time="$(stat -c %Y "$file")"
    fi

    echo $(( (now - mod_time) / 3600 ))
}

run_playwright_auth_flow() {
    local mode="$1"
    local site_url="$2"
    local auth_file="$3"
    local login_url="$4"
    local headless_val="$5"
    local exit_code

    set +e
    node "${SCRIPT_DIR}/pw-auth-helpers/auth-flow.js" "$mode" "$site_url" "$auth_file" "$login_url" "$headless_val"
    exit_code=$?
    set -e

    return $exit_code
}

run_playwright_dom_check() {
    local check_url="$1"
    local selector="$2"
    local extract_mode="$3"
    local auth_file="$4"
    local auth_origin="$5"
    local result_json="$6"
    local extract_file="$7"
    local timeout_ms="$8"
    local output_format="$9"
    local exit_code

    set +e
    node "${SCRIPT_DIR}/pw-auth-helpers/dom-check.js" "$check_url" "$selector" "$extract_mode" "$auth_file" "$auth_origin" "$result_json" "$extract_file" "$timeout_ms" "$output_format"
    exit_code=$?
    set -e

    return $exit_code
}

# ============================================================
# COMMANDS
# ============================================================

do_login() {
    local site_url=""
    local wp_user="admin"
    local wp_cli_cmd="wp"
    local redirect=""
    local max_age="$DEFAULT_MAX_AGE_HOURS"
    local force=false
    local auth_file=""
    local headed=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --site-url)   site_url="$2"; shift 2 ;;
            --user)       wp_user="$2"; shift 2 ;;
            --wp-cli)     wp_cli_cmd="$2"; shift 2 ;;
            --redirect)   redirect="$2"; shift 2 ;;
            --max-age)    max_age="$2"; shift 2 ;;
            --force)      force=true; shift ;;
            --auth-file)  auth_file="$2"; shift 2 ;;
            --headed)     headed="--headed"; shift ;;
            -h|--help)    show_help; exit 0 ;;
            *) log_error "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [ -z "$site_url" ]; then
        log_error "--site-url is required"
        echo ""
        show_help
        exit 1
    fi

    # Determine auth file path
    if [ -z "$auth_file" ]; then
        auth_file="$(default_auth_file_for_user "$wp_user")"
    fi

    # Check prerequisites
    if ! command -v node >/dev/null 2>&1; then
        log_error "Node.js is required but not installed."
        exit 1
    fi

    # Verify Playwright is resolvable by Node
    if ! ensure_playwright_resolvable; then
        log_error "Playwright is not resolvable by Node.js."
        log_error ""
        log_error "Install globally:  npm install -g playwright"
        log_error "Then install browsers:  npx playwright install chromium"
        log_error ""
        log_error "pw-auth already tried the global npm root from: npm root -g"
        log_error "If Node still can't find Playwright, set NODE_PATH manually:"
        log_error "  export NODE_PATH=\"\$(npm root -g)\""
        exit 1
    fi

    # Check cache
    if [ "$force" = false ] && [ -f "$auth_file" ]; then
        local age
        local validate_log
        local validate_summary

        age="$(file_age_hours "$auth_file")"
        if [ "$age" -lt "$max_age" ]; then
            log_info "Cached auth is ${age}h old (max: ${max_age}h). Verifying live session..."
            validate_log="$(create_temp_file "pw-auth-validate" ".log")" || {
                log_error "Failed to create temporary validation log file."
                return 1
            }
            track_temp_file "$validate_log"
            if run_playwright_auth_flow "validate" "$site_url" "$auth_file" "" "true" >"$validate_log" 2>&1; then
                cleanup_temp_file "$validate_log"
                log_info "Cached auth passed live validation. Reusing: $auth_file"
                log_info "Use --force to re-authenticate."
                exit 0
            fi

            if [ -s "$validate_log" ]; then
                validate_summary="$(tail -n 1 "$validate_log" | tr -d '\r')"
                if [ -n "$validate_summary" ]; then
                    log_info "Cached auth probe failed: $validate_summary"
                fi
            fi
            cleanup_temp_file "$validate_log"
            log_info "Cached auth is fresh but no longer valid. Re-authenticating..."
        else
            log_info "Cached auth is ${age}h old (max: ${max_age}h). Re-authenticating..."
        fi
    fi

    # Build WP-CLI login command as an array (no eval — avoids command injection)
    local parsed_wp_cli_cmd
    local cmd_part
    local wp_cmd_display
    local wp_prefix_display
    local stderr_file
    local -a wp_cmd_args
    local -a wp_cmd_prefix_args

    parsed_wp_cli_cmd="$(parse_command_prefix "$wp_cli_cmd")" || {
        log_error "Could not parse --wp-cli value: $wp_cli_cmd"
        log_error "Pass only a command prefix, e.g. --wp-cli \"local-wp my-site\""
        exit 1
    }

    while IFS= read -r cmd_part || [ -n "$cmd_part" ]; do
        wp_cmd_prefix_args+=("$cmd_part")
    done <<< "$parsed_wp_cli_cmd"

    wp_cmd_args=("${wp_cmd_prefix_args[@]}")
    wp_cmd_args+=( "dev" "login" "--user=$wp_user" "--format=url" )
    if [ -n "$redirect" ]; then
        wp_cmd_args+=( "--redirect=$redirect" )
    fi

    wp_cmd_display="$(join_args_for_display "${wp_cmd_args[@]}")"
    wp_prefix_display="$(join_args_for_display "${wp_cmd_prefix_args[@]}")"

    log_info "Generating one-time login URL..."
    log_info "Running: $wp_cmd_display"

    local login_url
    stderr_file="$(create_temp_file "pw-auth-wpcli" ".log")" || {
        log_error "Failed to create temporary WP-CLI stderr log file."
        return 1
    }
    track_temp_file "$stderr_file"
    login_url="$("${wp_cmd_args[@]}" 2>"$stderr_file")" || {
        log_error "WP-CLI command failed while generating the one-time login URL."
        if [ -s "$stderr_file" ]; then
            log_error "WP-CLI stderr:"
            while IFS= read -r line; do
                log_error "  $line"
            done < "$stderr_file"
        fi
        log_error "  Template: ~/bin/ai-ddtk/templates/dev-login-cli.php"
        log_error "  Install:  cp ~/bin/ai-ddtk/templates/dev-login-cli.php <site>/wp-content/mu-plugins/"
        log_error "Run these next:"
        log_error "  $wp_prefix_display option get home"
        log_error "  $wp_prefix_display eval 'echo wp_get_environment_type(), PHP_EOL;'"
        log_error "  $wp_prefix_display user get $wp_user --field=user_login"
        log_error "  $wp_prefix_display eval 'echo ( file_exists( WP_CONTENT_DIR . \"/mu-plugins/dev-login-cli.php\" ) ? \"mu-plugin present\" : \"mu-plugin missing\" ), PHP_EOL;'"
        log_error "  $wp_prefix_display dev login --user=$wp_user --format=url"
        cleanup_temp_file "$stderr_file"
        exit 1
    }
    cleanup_temp_file "$stderr_file"

    # Trim any whitespace / extra lines — take only the last line (the URL)
    login_url="$(echo "$login_url" | tail -n 1 | tr -d '[:space:]')"

    if [ -z "$login_url" ]; then
        log_error "No login URL returned from WP-CLI."
        exit 1
    fi

    # Validate that the login URL matches the expected --site-url origin
    local expected_origin
    local login_origin
    expected_origin="$(url_origin "$site_url")" || {
        log_error "Invalid --site-url: $site_url"
        exit 1
    }
    login_origin="$(url_origin "$login_url")" || {
        log_error "WP-CLI returned an invalid login URL: $login_url"
        exit 1
    }
    if [ "$login_origin" != "$expected_origin" ]; then
        log_error "Login URL origin mismatch."
        log_error "  Expected origin: $expected_origin"
        log_error "  Got origin:      $login_origin"
        log_error "  Got URL:         $login_url"
        log_error "Check that --site-url matches the site's home_url()."
        exit 1
    fi

    log_info "Login URL obtained. Launching Playwright to capture auth state..."

    # Create auth directory
    mkdir -p "$(dirname "$auth_file")"

    local headless_val
    headless_val="$( [ -n "$headed" ] && echo "false" || echo "true" )"

    run_playwright_auth_flow "login" "$site_url" "$auth_file" "$login_url" "$headless_val"

    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log_error "Playwright auth capture failed."
        exit 1
    fi

    log_info "Done. Use in Playwright scripts:"
    log_info "  storageState: '$auth_file'"
}

do_doctor() {
    local site_url=""
    local wp_user="admin"
    local wp_cli_cmd="wp"
    local output_format="text"
    local auth_file=""
    local displayed_auth_file=""
    local overall_status="ready"
    local auth_status="missing"
    local auth_exists=false
    local node_ready=false
    local playwright_ready=false
    local browser_launch_ready=false
    local site_origin=""
    local auth_age=""
    local parsed_wp_cli_cmd=""
    local cmd_part=""
    local wp_prefix_display=""
    local browser_probe_output=""
    local browser_executable_path=""
    local displayed_browser_path=""
    local browser_binary_exists="false"
    local browser_launch_ok="false"
    local browser_launch_message=""
    local validate_log=""
    local validate_summary=""
    local remediation=""
    local detail_json=""
    local status_label=""
    local symbol=""
    local i=0
    local -a check_names=()
    local -a check_statuses=()
    local -a check_summaries=()
    local -a check_details=()
    local -a remediations=()
    local -a wp_cmd_prefix_args=()

    add_check() {
        check_names+=("$1")
        check_statuses+=("$2")
        check_summaries+=("$3")
        check_details+=("${4:-}")

        case "$2" in
            fail)
                overall_status="blocked"
                ;;
            warn)
                if [ "$overall_status" = "ready" ]; then
                    overall_status="partial"
                fi
                ;;
        esac
    }

    add_remediation() {
        remediations+=("$1")
    }

    while [ $# -gt 0 ]; do
        case "$1" in
            --site-url)   site_url="$2"; shift 2 ;;
            --user)       wp_user="$2"; shift 2 ;;
            --wp-cli)     wp_cli_cmd="$2"; shift 2 ;;
            --format)     output_format="$2"; shift 2 ;;
            --auth-file)  auth_file="$2"; shift 2 ;;
            -h|--help)    show_help; exit 0 ;;
            *) log_error "Unknown option: $1"; exit 2 ;;
        esac
    done

    case "$output_format" in
        text|json)
            ;;
        *)
            log_error "--format must be 'text' or 'json'"
            exit 2
            ;;
    esac

    if [ -z "$site_url" ]; then
        log_error "--site-url is required"
        echo ""
        show_help
        exit 2
    fi

    if [ -z "$auth_file" ]; then
        auth_file="$(default_auth_file_for_user "$wp_user")"
    fi
    displayed_auth_file="$(display_path "$auth_file")"

    if command -v node >/dev/null 2>&1; then
        node_ready=true
        add_check "node" "pass" "Node.js detected: $(node -v 2>/dev/null || echo installed)"
    else
        add_check "node" "fail" "Node.js is required but not installed or not on PATH."
        add_remediation "Install Node.js and retry. Example: brew install node"
    fi

    if [ "$node_ready" = true ]; then
        site_origin="$(url_origin "$site_url" 2>/dev/null || true)"
        if [ -n "$site_origin" ]; then
            add_check "site_url" "pass" "Site URL is valid: $site_origin"
        else
            add_check "site_url" "fail" "Site URL is invalid: $site_url"
            add_remediation "Pass a valid --site-url, for example: --site-url http://my-site.local"
        fi

        parsed_wp_cli_cmd="$(parse_command_prefix "$wp_cli_cmd" 2>/dev/null || true)"
        if [ -n "$parsed_wp_cli_cmd" ]; then
            while IFS= read -r cmd_part || [ -n "$cmd_part" ]; do
                wp_cmd_prefix_args+=("$cmd_part")
            done <<< "$parsed_wp_cli_cmd"

            if [ ${#wp_cmd_prefix_args[@]} -gt 0 ]; then
                wp_prefix_display="$(join_args_for_display "${wp_cmd_prefix_args[@]}")"
                if command -v "${wp_cmd_prefix_args[0]}" >/dev/null 2>&1; then
                    add_check "wp_cli" "pass" "WP-CLI command prefix is available: $wp_prefix_display"
                else
                    add_check "wp_cli" "fail" "WP-CLI command is not available: ${wp_cmd_prefix_args[0]}"
                    add_remediation "Install WP-CLI or pass a valid prefix via --wp-cli \"local-wp <site>\"."
                fi
            else
                add_check "wp_cli" "fail" "Could not parse --wp-cli value: $wp_cli_cmd"
                add_remediation "Pass only a command prefix, for example: --wp-cli \"local-wp my-site\""
            fi
        else
            add_check "wp_cli" "fail" "Could not parse --wp-cli value: $wp_cli_cmd"
            add_remediation "Pass only a command prefix, for example: --wp-cli \"local-wp my-site\""
        fi

        if ensure_playwright_resolvable true; then
            playwright_ready=true
            add_check "playwright_module" "pass" "Playwright is resolvable by Node.js."
        else
            add_check "playwright_module" "fail" "Playwright is not resolvable by Node.js."
            add_remediation "Install Playwright globally: npm install -g playwright"
            add_remediation "Install Chromium for Playwright: npx playwright install chromium"
            add_remediation "If Playwright is installed globally but still not found, export NODE_PATH=\"\$(npm root -g)\" and retry."
        fi
    else
        add_check "site_url" "skip" "Skipped URL validation because Node.js is unavailable."
        add_check "wp_cli" "skip" "Skipped WP-CLI command validation because Node.js is unavailable."
        add_check "playwright_module" "skip" "Skipped Playwright resolution because Node.js is unavailable."
    fi

    if [ "$playwright_ready" = true ]; then
        browser_probe_output="$(node - <<'NODE'
const fs = require('node:fs');
let chromium;

try {
  ({ chromium } = require('playwright'));
} catch {
  ({ chromium } = require('playwright-core'));
}

const clean = (value) => String(value ?? '').replace(/\r?\n/g, ' ').trim();

(async () => {
  let browser = null;
  let executablePath = '';
  let binaryExists = false;
  let launchOk = false;
  let launchMessage = '';

  try {
    executablePath = typeof chromium.executablePath === 'function' ? chromium.executablePath() : '';
    binaryExists = Boolean(executablePath) && fs.existsSync(executablePath);
  } catch (error) {
    launchMessage = error && error.message ? error.message : String(error);
  }

  try {
    browser = await chromium.launch({ headless: true });
    launchOk = true;
    launchMessage = 'Chromium launched successfully.';
  } catch (error) {
    launchMessage = error && error.message ? error.message : String(error);
  } finally {
    if (browser) {
      await browser.close().catch(() => {});
    }
  }

  console.log(`executablePath=${clean(executablePath)}`);
  console.log(`binaryExists=${binaryExists ? 'true' : 'false'}`);
  console.log(`launchOk=${launchOk ? 'true' : 'false'}`);
  console.log(`launchMessage=${clean(launchMessage)}`);
})().catch((error) => {
  console.error(error && error.message ? error.message : String(error));
  process.exit(1);
});
NODE
        )"

        browser_executable_path="$(printf '%s\n' "$browser_probe_output" | sed -n 's/^executablePath=//p' | tail -n 1)"
        displayed_browser_path="$(display_path "$browser_executable_path")"
        browser_binary_exists="$(printf '%s\n' "$browser_probe_output" | sed -n 's/^binaryExists=//p' | tail -n 1)"
        browser_launch_ok="$(printf '%s\n' "$browser_probe_output" | sed -n 's/^launchOk=//p' | tail -n 1)"
        browser_launch_message="$(printf '%s\n' "$browser_probe_output" | sed -n 's/^launchMessage=//p' | tail -n 1)"

        if [ "$browser_binary_exists" = "true" ]; then
            add_check "browser_binary" "pass" "Chromium executable found: $displayed_browser_path"
        else
            add_check "browser_binary" "fail" "Chromium executable is missing for Playwright." "$displayed_browser_path"
            add_remediation "Install Chromium for Playwright: npx playwright install chromium"
        fi

        if [ "$browser_launch_ok" = "true" ]; then
            browser_launch_ready=true
            add_check "browser_launch" "pass" "${browser_launch_message:-Chromium launched successfully.}"
        else
            add_check "browser_launch" "fail" "Chromium failed to launch." "$browser_launch_message"
            add_remediation "Verify Playwright's browser install and local browser dependencies, then retry."
        fi
    else
        add_check "browser_binary" "skip" "Skipped browser binary check because Playwright is not resolvable."
        add_check "browser_launch" "skip" "Skipped browser launch because Playwright is not resolvable."
    fi

    if [ -f "$auth_file" ]; then
        auth_exists=true
        auth_status="present"
        auth_age="$(file_age_hours "$auth_file")"
        add_check "auth_file" "pass" "Cached auth file found: $displayed_auth_file (${auth_age}h old)"
    else
        add_check "auth_file" "warn" "No cached auth file found for user '$wp_user': $displayed_auth_file"
        add_remediation "Create or refresh cached auth with: pw-auth login --site-url $site_url --wp-cli \"$wp_cli_cmd\" --user $wp_user"
    fi

    if [ "$auth_exists" = true ] && [ -n "$site_origin" ] && [ "$browser_launch_ready" = true ]; then
        validate_log="$(create_temp_file "pw-auth-doctor" ".log")" || {
            add_check "cached_auth" "fail" "Could not create a temporary log file for cached auth validation."
            add_remediation "Retry the doctor command. If the problem persists, check TMPDIR permissions."
        }

        if [ -n "$validate_log" ]; then
            track_temp_file "$validate_log"
            if run_playwright_auth_flow "validate" "$site_url" "$auth_file" "" "true" >"$validate_log" 2>&1; then
                cleanup_temp_file "$validate_log"
                auth_status="valid"
                add_check "cached_auth" "pass" "Cached auth reaches /wp-admin/ without redirecting to login."
            else
                if [ -s "$validate_log" ]; then
                    validate_summary="$(tail -n 1 "$validate_log" | tr -d '\r')"
                else
                    validate_summary="Cached auth validation failed."
                fi
                cleanup_temp_file "$validate_log"
                auth_status="invalid"
                add_check "cached_auth" "warn" "Cached auth did not validate cleanly." "$validate_summary"
                add_remediation "Refresh the cached session with: pw-auth login --site-url $site_url --wp-cli \"$wp_cli_cmd\" --user $wp_user --force"
            fi
        fi
    elif [ "$auth_exists" != true ]; then
        add_check "cached_auth" "skip" "Skipped cached auth validation because no auth file is present."
    else
        add_check "cached_auth" "skip" "Skipped cached auth validation because browser or site prerequisites were not ready."
    fi

    if [ "$output_format" = "json" ]; then
        printf '{\n'
        printf '  "status": "%s",\n' "$(json_escape "$overall_status")"
        printf '  "site_url": "%s",\n' "$(json_escape "$site_url")"
        printf '  "user": "%s",\n' "$(json_escape "$wp_user")"
        printf '  "checks": [\n'
        for ((i = 0; i < ${#check_names[@]}; i++)); do
            if [ -n "${check_details[$i]}" ]; then
                detail_json="\"$(json_escape "${check_details[$i]}")\""
            else
                detail_json="null"
            fi

            printf '    {"name": "%s", "status": "%s", "summary": "%s", "detail": %s}' \
                "$(json_escape "${check_names[$i]}")" \
                "$(json_escape "${check_statuses[$i]}")" \
                "$(json_escape "${check_summaries[$i]}")" \
                "$detail_json"

            if [ $i -lt $((${#check_names[@]} - 1)) ]; then
                printf ','
            fi
            printf '\n'
        done
        printf '  ],\n'
        printf '  "auth": {"exists": %s, "file_path": "%s", "status": "%s"},\n' \
            "$([ "$auth_exists" = true ] && echo true || echo false)" \
            "$(json_escape "$displayed_auth_file")" \
            "$(json_escape "$auth_status")"
        printf '  "remediations": ['
        for ((i = 0; i < ${#remediations[@]}; i++)); do
            printf '"%s"' "$(json_escape "${remediations[$i]}")"
            if [ $i -lt $((${#remediations[@]} - 1)) ]; then
                printf ', '
            fi
        done
        printf ']\n'
        printf '}\n'
    else
        echo "[pw-auth] Doctor status: $overall_status"
        echo "[pw-auth] Site URL: $site_url"
        echo "[pw-auth] User: $wp_user"
        echo "[pw-auth] Auth file: $displayed_auth_file"
        echo "[pw-auth]"
        echo "[pw-auth] Checks:"
        for ((i = 0; i < ${#check_names[@]}; i++)); do
            case "${check_statuses[$i]}" in
                pass) symbol="✓" ;;
                warn) symbol="○" ;;
                fail) symbol="✗" ;;
                *)    symbol="-" ;;
            esac
            status_label="$(printf '%s' "${check_statuses[$i]}" | tr '[:lower:]' '[:upper:]')"
            echo "[pw-auth]   $symbol [${status_label}] ${check_names[$i]} — ${check_summaries[$i]}"
            if [ -n "${check_details[$i]}" ]; then
                echo "[pw-auth]       ${check_details[$i]}"
            fi
        done

        if [ ${#remediations[@]} -gt 0 ]; then
            echo "[pw-auth]"
            echo "[pw-auth] Remediations:"
            for ((i = 0; i < ${#remediations[@]}; i++)); do
                echo "[pw-auth]   $((i + 1)). ${remediations[$i]}"
            done
        fi
    fi

    case "$overall_status" in
        ready)   exit 0 ;;
        partial) exit 1 ;;
        *)       exit 2 ;;
    esac
}

do_check_dom() {
    local check_url=""
    local selector=""
    local extract_mode=""
    local wp_user="admin"
    local auth_state=""
    local auth_origin=""
    local timeout_ms="$DEFAULT_CHECK_TIMEOUT_MS"
    local output_format="text"
    local output_dir=""
    local auth_file=""
    local run_id=""
    local result_json=""
    local extract_file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --url)         check_url="$2"; shift 2 ;;
            --selector)    selector="$2"; shift 2 ;;
            --extract)     extract_mode="$2"; shift 2 ;;
            --user)        wp_user="$2"; shift 2 ;;
            --auth-state)  auth_state="$2"; shift 2 ;;
            --auth-origin) auth_origin="$2"; shift 2 ;;
            --timeout-ms)  timeout_ms="$2"; shift 2 ;;
            --format)      output_format="$2"; shift 2 ;;
            --output-dir)  output_dir="$2"; shift 2 ;;
            -h|--help)     show_help; exit 0 ;;
            *) log_error "Unknown option: $1"; exit 2 ;;
        esac
    done

    if [ -z "$check_url" ] || [ -z "$selector" ] || [ -z "$extract_mode" ]; then
        log_error "--url, --selector, and --extract are required"
        echo ""
        show_help
        exit 2
    fi

    case "$extract_mode" in
        exists|text|html)
            ;;
        *)
            log_error "--extract must be one of: exists, text, html"
            exit 2
            ;;
    esac

    case "$output_format" in
        text|json)
            ;;
        *)
            log_error "--format must be 'text' or 'json'"
            exit 2
            ;;
    esac

    case "$timeout_ms" in
        ''|*[!0-9]*)
            log_error "--timeout-ms must be a positive integer"
            exit 2
            ;;
    esac

    if ! command -v node >/dev/null 2>&1; then
        log_error "Node.js is required but not installed."
        exit 5
    fi

    if ! ensure_playwright_resolvable; then
        log_error "Playwright is not resolvable by Node.js."
        log_error "Install globally:  npm install -g playwright"
        log_error "Then install browsers:  npx playwright install chromium"
        exit 5
    fi

    if [ -z "$auth_origin" ]; then
        auth_origin="$(url_origin "$check_url" 2>/dev/null || true)"
    else
        auth_origin="$(url_origin "$auth_origin" 2>/dev/null || true)"
    fi

    if [ -z "$auth_origin" ]; then
        log_error "Could not determine a valid auth origin from --url/--auth-origin"
        exit 2
    fi

    if [ -n "$auth_state" ]; then
        auth_file="$auth_state"
    else
        auth_file="$(default_auth_file_for_user "$wp_user")"
    fi

    if [ -z "$output_dir" ]; then
        run_id="$(date -u +%Y%m%dT%H%M%SZ)-$$"
        output_dir="$(pwd)/temp/playwright/checks/$run_id"
    elif [ "${output_dir#/}" = "$output_dir" ]; then
        output_dir="$(pwd)/$output_dir"
    fi

    mkdir -p "$output_dir"
    result_json="$output_dir/result.json"

    case "$extract_mode" in
        text)
            extract_file="$output_dir/extract.txt"
            ;;
        html)
            extract_file="$output_dir/extract.html"
            ;;
        *)
            extract_file=""
            ;;
    esac

    run_playwright_dom_check "$check_url" "$selector" "$extract_mode" "$auth_file" "$auth_origin" "$result_json" "$extract_file" "$timeout_ms" "$output_format"
    exit $?
}

do_check() {
    local subcommand="${1:-}"
    shift || true

    case "$subcommand" in
        dom)
            do_check_dom "$@"
            ;;
        ""|-h|--help)
            show_help
            exit 0
            ;;
        *)
            log_error "Unknown check subcommand: $subcommand"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

do_status() {
    mkdir -p "$AUTH_DIR"

    local found=false
    for f in "$AUTH_DIR"/*.json; do
        [ -f "$f" ] || continue
        found=true
        local age
        age="$(file_age_hours "$f")"
        local user
        user="$(basename "$f" .json)"
        local size
        size="$(wc -c < "$f" | tr -d ' ')"

        echo "  User: $user"
        echo "  File: $f"
        echo "  Age:  ${age}h"
        echo "  Size: ${size} bytes"

        if [ "$age" -lt "$DEFAULT_MAX_AGE_HOURS" ]; then
            echo "  Status: FRESH (< ${DEFAULT_MAX_AGE_HOURS}h; live validation happens on login)"
        else
            echo "  Status: STALE (>= ${DEFAULT_MAX_AGE_HOURS}h, will re-auth on next login)"
        fi
        echo ""
    done

    if [ "$found" = false ]; then
        echo "No cached auth state found in $AUTH_DIR"
        echo "Run: pw-auth login --site-url <url>"
    fi
}

do_clear() {
    if [ -d "$AUTH_DIR" ]; then
        rm -f "$AUTH_DIR"/*.json
        log_info "Cleared auth state from $AUTH_DIR"
    else
        log_info "No auth directory found. Nothing to clear."
    fi
}

# ============================================================
# MAIN
# ============================================================

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    login)
        do_login "$@"
        ;;
    doctor)
        do_doctor "$@"
        ;;
    check)
        do_check "$@"
        ;;
    status)
        do_status
        ;;
    clear)
        do_clear
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        log_error "Unknown command: $COMMAND"
        echo ""
        show_help
        exit 1
        ;;
esac
