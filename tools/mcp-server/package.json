{
  "name": "ai-ddtk-mcp",
  "version": "0.1.0",
  "description": "AI-DDTK MCP server for LocalWP and toolkit command orchestration",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "ai-ddtk-mcp": "./dist/src/index.js"
  },
