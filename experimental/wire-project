#!/bin/bash
# wire-project — Wire a WordPress project for AI-DDTK MCP integration
# Usage: wire-project [project_path]
# If no path provided, uses current directory

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get project path (default to current directory)
PROJECT_PATH="${1:-.}"

# Resolve to absolute path
if [[ ! "$PROJECT_PATH" = /* ]]; then
  PROJECT_PATH="$(cd "$PROJECT_PATH" && pwd)"
fi

# Verify project path exists
if [[ ! -d "$PROJECT_PATH" ]]; then
  echo -e "${RED}✗ Error: Project path does not exist: $PROJECT_PATH${NC}"
  exit 1
fi

echo -e "${BLUE}Wiring project for AI-DDTK...${NC}"
echo "Project path: $PROJECT_PATH"
echo ""

# Step 1: Check AI-DDTK installation
echo -n "Checking AI-DDTK installation... "
if [[ ! -d "$HOME/bin/ai-ddtk" ]]; then
  echo -e "${RED}✗${NC}"
  echo -e "${RED}Error: AI-DDTK not found at $HOME/bin/ai-ddtk${NC}"
  echo "Please run: ~/bin/ai-ddtk/install.sh"
  exit 1
fi
echo -e "${GREEN}✓${NC}"

# Step 2: Detect home directory
echo -n "Detecting home directory... "
HOME_DIR="$HOME"
echo -e "${GREEN}✓${NC} ($HOME_DIR)"

# Step 3: Create .mcp.local.json
echo -n "Creating .mcp.local.json... "
MCP_LOCAL_FILE="$PROJECT_PATH/.mcp.local.json"

cat > "$MCP_LOCAL_FILE" << EOF
{
  "mcpServers": {
    "ai-ddtk": {
      "command": "bash",
      "args": ["$HOME_DIR/bin/ai-ddtk/tools/mcp-server/start.sh"]
    }
  }
}
EOF

echo -e "${GREEN}✓${NC}"

# Step 4: Update .gitignore
echo -n "Updating .gitignore... "
GITIGNORE_FILE="$PROJECT_PATH/.gitignore"

if [[ ! -f "$GITIGNORE_FILE" ]]; then
  touch "$GITIGNORE_FILE"
fi

if ! grep -q "^\.mcp\.local\.json$" "$GITIGNORE_FILE"; then
  echo ".mcp.local.json" >> "$GITIGNORE_FILE"
fi

echo -e "${GREEN}✓${NC}"

# Step 5: Add CLAUDE.md reference (append, never overwrite)
echo -n "Adding CLAUDE.md reference... "
CLAUDE_MD="$PROJECT_PATH/CLAUDE.md"
CLAUDE_REF="AI-DDTK is installed at ~/bin/ai-ddtk — see ~/bin/ai-ddtk/AGENTS.md for available tools and workflows."

if [[ ! -f "$CLAUDE_MD" ]]; then
  echo "# CLAUDE.md" > "$CLAUDE_MD"
  echo "" >> "$CLAUDE_MD"
  echo "$CLAUDE_REF" >> "$CLAUDE_MD"
elif ! grep -q "ai-ddtk/AGENTS.md" "$CLAUDE_MD"; then
  # Prepend reference after the first line (title)
  sed -i '' "1a\\
\\
$CLAUDE_REF
" "$CLAUDE_MD"
fi

echo -e "${GREEN}✓${NC}"

# Step 6: Summary
echo ""
echo -e "${GREEN}✓ Project wired! Ready to use AI-DDTK.${NC}"
echo ""
echo "Next steps:"
echo "  1. Restart your editor/agent session"
echo "  2. Run: ~/bin/ai-ddtk/preflight.sh"
echo "  3. Start coding!"
echo ""
echo "Files created/updated:"
echo "  • .mcp.local.json (local MCP configuration)"
echo "  • .gitignore (added .mcp.local.json)"
echo "  • CLAUDE.md (AI agent reference)"

